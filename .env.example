# nfe — persistência (etapa 2).
#
# ⚠️  Este repositório é PÚBLICO. NÃO comite credenciais reais.
#     Guarde o arquivo com a senha FORA do repo (ex.: ../../control/nfe.env)
#     e aponte NFE_ENV para ele, ou exporte NFE_DB_URL no ambiente:
#
#         NFE_ENV=/caminho/para/control/nfe.env  uv run --extra db nfe --salvar <url>

# Conexão Postgres do Supabase (role de serviço, via session pooler IPv4).
NFE_DB_URL=postgresql://bot_notas.<ref>:<senha>@aws-1-us-east-2.pooler.supabase.com:5432/postgres

# Alternativa: caminho de um arquivo de ambiente (carregado se python-dotenv existir).
# NFE_ENV=/home/voce/Projetos/notas-fiscais/control/nfe.env
